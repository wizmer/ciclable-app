## Local Configuration (NOT committed to git)
## Copy this file to local.properties and fill in your values

# Flutter SDK path (auto-generated by Flutter)
sdk.dir=/path/to/flutter/sdk
flutter.sdk=/path/to/flutter/sdk

# Google Maps API Keys
# Get keys from: https://console.cloud.google.com/google/maps-apis
# Restrict keys by package name: org.ciclable.app

# Debug key - restricted to debug SHA-1 fingerprint
# Used during development, can have looser restrictions
google.maps.key.debug=AIzaSy_YOUR_DEBUG_KEY_HERE

# Release key - restricted to release SHA-1 fingerprint
# Used in production builds, should have strict restrictions
google.maps.key.release=AIzaSy_YOUR_RELEASE_KEY_HERE

## Security Notes:
## 1. NEVER commit local.properties to git (already in .gitignore)
## 2. Use separate API keys for debug and release
## 3. Restrict each key to its respective SHA-1 fingerprint
## 4. Enable only required APIs (Maps SDK for Android)
## 5. Set usage quotas to prevent unexpected billing
